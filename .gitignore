# ===== MPLS-TE lab .gitignore =====
# Keeps the repo to lab content only: README, configs/, docs/, notes/, *.unl
# Everything below is local junk that shouldn't be pushed.

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*~

# --- EVE-NG / temp lab artifacts ---
*.tmp
*.bak
*.log
*.old
__pycache__/

# --- EVE-NG topology export (kept local, not published) ---
*.unl

# --- Helper scripts that live in the parent folder, not the repo ---
push-*.ps1
push-*.bat
push-via-api.ps1

# --- Internal working files — never publish ---
HANDOFF.md

# --- Private files (convention: *.private.* or a private/ folder) ---
private/
*.private.*
*-private.*
PRIVATE*

# --- Credentials & secrets ---
.env
.env.*
*.pem
*.key
*.token
*credentials*
*secret*
inventory*.yaml
inventory*.ini

# --- Work-data safety net (public repo; work stays sanitized) ---
# Force-add a genuinely safe file with: git add -f <file>
*work-notes*
*internal*
